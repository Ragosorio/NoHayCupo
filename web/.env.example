# Variables de entorno de NoHayCupo (todas opcionales: hay defaults sanos).
# En Vercel se cargan en Project Settings -> Environment Variables.

# Sitios de la facultad (por si algún día cambian de dominio)
HORARIOS_BASE_URL=https://usuarios.ingenieria.usac.edu.gt
REDES_BASE_URL=https://redesestudio.ingenieria.usac.edu.gt

# TTLs de caché en segundos (CDN + memoria de la función)
CACHE_CATALOGO_SEGUNDOS=21600
CACHE_PENSUM_SEGUNDOS=2592000
CACHE_RESTRICCIONES_SEGUNDOS=604800

# Identificación ante los sitios scrapeados (sé buen ciudadano)
SCRAPER_USER_AGENT="NoHayCupo/2.0 (github.com/Ragosorio/NoHayCupo)"
